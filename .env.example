# Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# JWT Secret (change this in production!)
JWT_SECRET=mobimech-secret-key-change-in-production-2026

# Email Configuration (SMTP)
# For development, emails are logged to console
# For production, configure your SMTP server
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@mobimech.com
EMAIL_FROM_NAME=MobiMech Mobile Mechanics

# Admin Default Credentials (used by seed script)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
